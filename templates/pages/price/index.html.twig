{% extends 'base.html.twig' %}

{% block title %}Prices{% endblock %}

{% block body %}
{{ component('Hero', {
  title: 'Pricing Plans',
  subtitle: "Choose the perfect plan for your team and start boosting your productivity today.",
  size: 'xs'
}) }}

<div class="relative py-20 bg-gradient-to-br from-slate-900 via-slate-800 to-black overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">

        <!-- Desktop View - Cards -->
        <div class="hidden lg:flex justify-center items-stretch gap-8 mt-8 mb-24">
            <!-- Free Plan -->
            <div class="card bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl shadow-lg shadow-blue-500/10 w-80 transform hover:scale-105 hover:shadow-cyan-500/20 transition-all duration-300">
                <div class="card-body">
                    <div class="text-center mb-6">
                        <div class="avatar placeholder mb-4">
                            <div class="bg-neutral text-neutral-content rounded-full w-16">
                                <i class="fa-solid fa-cube text-2xl"></i>
                            </div>
                        </div>
                        <h3 class="text-2xl font-bold text-white">Free</h3>
                        <div class="flex items-baseline justify-center mt-2">
                            <span class="text-4xl font-extrabold text-white">$0</span>
                            <span class="text-base-content/60 ml-1">/month</span>
                        </div>
                    </div>

                    <div class="divider"></div>

                    <ul class="space-y-3 mb-8">
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Create and organize tasks</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Assign tasks and update status</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Add labels and descriptions</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Simple due dates</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Basic filtering and sorting</span>
                        </li>
                    </ul>
                    <div class="card-actions justify-center">
                        <a href="#" class="px-6 py-3 bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-600 
                           hover:from-cyan-400 hover:via-blue-400 hover:to-purple-500 
                           text-white font-semibold rounded-xl transition-all duration-300 
                           shadow-xl hover:shadow-cyan-500/30 transform hover:scale-105 hover:-translate-y-0.5 w-full text-center">
                           Get Started
                        </a>
                    </div>
                </div>
            </div>

            <!-- Starter Plan -->
            <div class="card bg-white/10 backdrop-blur-xl border-2 border-cyan-500 rounded-2xl shadow-xl shadow-cyan-500/30 w-80 transform scale-105 hover:scale-110 transition-all duration-300 relative">
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-cyan-500 to-purple-600 text-white text-xs font-semibold px-3 py-1 rounded-full shadow-md">
                    Most Popular
                </div>
                <div class="card-body">
                    <div class="text-center mb-6">
                        <div class="avatar placeholder mb-4">
                            <div class="bg-primary-content text-primary rounded-full w-16">
                                <i class="fa-solid fa-star text-2xl text-purple-400"></i>
                            </div>
                        </div>
                        <h3 class="text-2xl font-bold text-white">Starter</h3>
                        <div class="flex items-baseline justify-center mt-2">
                            <span class="text-4xl font-extrabold text-white">$9.99</span>
                            <span class="opacity-70 ml-1">/month</span>
                        </div>
                    </div>

                    <div class="divider divider-neutral"></div>

                    <ul class="space-y-3 mb-8">
                        <li class="flex items-center gap-3">
                            <div class="badge badge-accent badge-sm">✓</div>
                            <span class="text-sm">All Free features</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-accent badge-sm">✓</div>
                            <span class="text-sm">Task comments</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-accent badge-sm">✓</div>
                            <span class="text-sm">Email notifications</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-accent badge-sm">✓</div>
                            <span class="text-sm">Calendar & timeline views</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-accent badge-sm">✓</div>
                            <span class="text-sm">Advanced filtering</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-accent badge-sm">✓</div>
                            <span class="text-sm">Custom labels & colors</span>
                        </li>
                    </ul>
                    <div class="card-actions justify-center">
                        <a href="#" class="px-6 py-3 bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-600 
                           hover:from-cyan-400 hover:via-blue-400 hover:to-purple-500 
                           text-white font-semibold rounded-xl transition-all duration-300 
                           shadow-xl hover:shadow-cyan-500/30 transform hover:scale-105 hover:-translate-y-0.5 w-full text-center">
                           Start Free Trial
                        </a>
                    </div>
                </div>
            </div>

            <!-- Premium Plan -->
            <div class="card bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl shadow-lg shadow-blue-500/10 w-80 transform hover:scale-105 hover:shadow-cyan-500/20 transition-all duration-300">
                <div class="card-body">
                    <div class="text-center mb-6">
                        <div class="avatar placeholder mb-4">
                            <div class="bg-gradient-to-br from-primary to-secondary text-white rounded-full w-16">
                                <i class="fa-solid fa-crown text-2xl text-yellow-400"></i>
                            </div>
                        </div>
                        <h3 class="text-2xl font-bold text-white">Premium</h3>
                        <div class="flex items-baseline justify-center mt-2">
                            <span class="text-4xl font-extrabold text-white">$19.99</span>
                            <span class="text-base-content/60 ml-1">/month</span>
                        </div>
                    </div>

                    <div class="divider"></div>

                    <ul class="space-y-3 mb-8">
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">All Starter features</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Newsletter system</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Advanced integrations</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Priority support</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <div class="badge badge-success badge-sm">✓</div>
                            <span class="text-sm">Personalized onboarding</span>
                        </li>
                    </ul>
                    <div class="card-actions justify-center">
                        <a href="#" class="px-6 py-3 bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-600 
                           hover:from-cyan-400 hover:via-blue-400 hover:to-purple-500 
                           text-white font-semibold rounded-xl transition-all duration-300 
                           shadow-xl hover:shadow-cyan-500/30 transform hover:scale-105 hover:-translate-y-0.5 w-full text-center">
                           Upgrade Now
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {% include 'pages/price/resp_price.html.twig'  %}

        <!-- Carousel indicators -->
        <div class="lg:hidden mt-8">
            <div class="flex justify-center w-full py-2 gap-2 mt-4">
                <a href="#slide1" class="btn btn-xs">1</a>
                <a href="#slide2" class="btn btn-xs">2</a>
                <a href="#slide3" class="btn btn-xs">3</a>
            </div>
        </div>

        <!-- Features Comparison Table -->
        <div class="mt-32 mb-16">
            <div class="text-center mb-8">
                <h3 class="text-3xl font-bold text-white mb-4">Compare all features</h3>
                <p class="text-slate-300">See what's included in each plan</p>
            </div>

            <div class="overflow-x-auto max-w-4xl mx-auto shadow-lg shadow-blue-500/10">
                <table class="table bg-white/5 backdrop-blur-xl border border-white/10 rounded-lg shadow-lg shadow-blue-500/10">
                    <thead>
                        <tr class="text-white">
                            <th class="text-left">Features</th>
                            <th class="text-center">Free</th>
                            <th class="text-center">Starter</th>
                            <th class="text-center">Premium</th>
                        </tr>
                    </thead>
                    <tbody class="text-slate-300">
                        <tr>
                            <td class="font-medium">Task Management</td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                        </tr>
                        <tr>
                            <td class="font-medium">Email Notifications</td>
                            <td class="text-center"><div class="badge badge-error badge-sm">✗</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                        </tr>
                        <tr>
                            <td class="font-medium">Advanced Views</td>
                            <td class="text-center"><div class="badge badge-error badge-sm">✗</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                        </tr>
                        <tr>
                            <td class="font-medium">Newsletter System</td>
                            <td class="text-center"><div class="badge badge-error badge-sm">✗</div></td>
                            <td class="text-center"><div class="badge badge-error badge-sm">✗</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                        </tr>
                        <tr>
                            <td class="font-medium">Priority Support</td>
                            <td class="text-center"><div class="badge badge-error badge-sm">✗</div></td>
                            <td class="text-center"><div class="badge badge-error badge-sm">✗</div></td>
                            <td class="text-center"><div class="badge badge-success badge-sm">✓</div></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{# CTA Section #}
{% include 'pages/home/_cta.html.twig' %}

{% endblock %}