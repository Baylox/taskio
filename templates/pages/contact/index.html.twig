{% extends 'base.html.twig' %}

{% block title %}Contact Us{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-base-200">
    <div class="card w-full max-w-2xl shadow-2xl bg-base-100">
        <div class="col-lg-8">
            <div class="card-body">
                <div class="card-body items-center justify-center">
                   <div class="card-header text-white">
                    <h2 class="text-3xl font-bold text-center mb-6">Get in Touch</h2>
                </div> 
                   
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    <p class="text-center text-base-content/70 mb-8">
                        Have a question or want to get in touch? Send us a message and we'll get back to you as soon as possible.
                    </p>

                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.name, {'attr': {'class': 'input input-bordered w-full'}}) }}
                            </div>
                            <div class="form-control">
                                {{ form_row(form.email, {'attr': {'class': 'input input-bordered w-full'}}) }}
                            </div>
                        </div>
                        
                        <div class="form-control mb-4">
                            {{ form_row(form.subject, {'attr': {'class': 'input input-bordered w-full'}}) }}
                        </div>
                        
                        <div class="form-control mb-6">
                            {{ form_row(form.message, {'attr': {'class': 'textarea textarea-bordered w-full h-32'}}) }}
                        </div>

                        <div class="d-none" aria-hidden="true">
                            {{ form_widget(form.website) }}
                        </div>

                        <div class="form-control">
                            <button type="submit" class="btn btn-primary btn-block">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                                </svg>
                                Send Message
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
