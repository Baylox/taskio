{# templates/partials/_cta.html.twig #}
<section class="relative bg-gradient-to-br from-[#2b3e5f] via-[#1e2d47] to-[#1a2332] py-32 text-center overflow-hidden">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-blue-700 via-slate-800 to-black hero-gradient-shift"></div>

    <!-- Animated decorative blobs -->
    <div class="absolute top-10 left-10 w-40 h-40 rounded-full bg-indigo-500 opacity-20 hero-float"></div>
    <div class="absolute top-20 right-20 w-56 h-56 rounded-full bg-purple-500 opacity-20 hero-float-delayed"></div>
    <div class="absolute bottom-10 left-32 w-48 h-48 rounded-full bg-blue-500 opacity-20 hero-float-slow"></div>
    <div class="absolute bottom-24 right-40 w-32 h-32 rounded-full bg-pink-500 opacity-20 hero-float"></div>
    <div class="absolute top-1/4 left-0 w-28 h-28 rounded-full bg-indigo-400 opacity-20 hero-float-delayed"></div>
    <div class="absolute bottom-1/3 right-0 w-36 h-36 rounded-full bg-purple-400 opacity-20 hero-float-slow"></div>
    <div class="absolute top-1/3 right-1/4 w-20 h-20 rounded-full bg-blue-400 opacity-20 hero-float"></div>
    <div class="absolute bottom-1/4 left-1/4 w-24 h-24 rounded-full bg-pink-400 opacity-20 hero-float-delayed"></div>
    <div class="relative max-w-3xl mx-auto px-6 z-10">

        

        {# Title - Large and bold like hero #}
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-8 text-white leading-tight">
            Ready when you are
        </h2>

        {# Main description #}
        <p class="text-lg md:text-xl text-gray-300 mb-10 leading-relaxed max-w-2xl mx-auto">
            Forget clunky and cheap. Unleash your productivity with Taskio!
        </p>

        {# CTA button - exactly like hero button #}
        <a
            href="#"
            class="inline-block bg-gradient-to-r from-[#00d4ff] to-[#a855f7] text-white font-semibold text-lg py-4 px-10 rounded-xl transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(0,212,255,0.4)]"
        >
            Now, let's build something great
        </a>

        {# Optional: Tagline below #}
        <p class="mt-8 text-base text-gray-400">
            <span class="text-white font-semibold">Taskio.</span> Your board, your power.
        </p>
    </div>
</section>