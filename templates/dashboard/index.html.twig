{# templates/dashboard/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
	<div class="min-h-screen bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800">
		{# Header #}
		<div class="bg-slate-800/50 backdrop-blur-sm border-b border-slate-700/50 px-6 py-4">
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-bold text-white mb-1">{{ board.name ?? 'Dashboard' }}</h1>
					<p class="text-slate-400 text-sm">Manage your project tasks and workflows</p>
				</div>
				<label for="lane_create_modal"
					class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-400 hover:to-blue-400 text-white font-medium rounded-lg transition-all duration-200 shadow-lg hover:shadow-cyan-500/25 cursor-pointer">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
					</svg>
					Add Lane
				</label>
			</div>
		</div>

		{# Main Dashboard Content #}
		<div class="p-6">
			<div class="dashboard flex gap-6 overflow-x-auto pb-6" id="board-lanes">
				{% for lane in board.lanes %}
					<div class="lane-wrapper flex-shrink-0">
						{% include 'components/Lane.html.twig' with { lane: lane } %}
					</div>
				{% endfor %}

				{# Empty State or Add Lane Placeholder #}
				{% if board.lanes|length == 0 %}
					<div class="flex-shrink-0 w-80 h-96 border-2 border-dashed border-slate-600 rounded-xl flex flex-col items-center justify-center text-slate-400 bg-slate-800/30 backdrop-blur-sm">
						<svg class="w-16 h-16 mb-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
						</svg>
						<h3 class="text-lg font-medium mb-2">No lanes yet</h3>
						<p class="text-sm text-center">Create your first lane to start organizing tasks</p>
					</div>
				{% endif %}
			</div>
		</div>

		{# Floating Action Button for Mobile #}
		<div class="fixed bottom-6 right-6 lg:hidden">
			<label for="lane_create_modal"
				   class="flex items-center justify-center w-14 h-14 bg-gradient-to-r from-cyan-500 to-blue-500 text-white rounded-full shadow-lg hover:shadow-cyan-500/25 cursor-pointer transition-all duration-200 hover:scale-110">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
				</svg>
			</label>
		</div>

		{# Include Create modal #}
		{% include 'dashboard/new_lane.html.twig' with {
			form: laneForm,
			board: board,
			checked: openLaneModal|default(false)
		} only %}

		{# Include all Edit modals #}
		{% for lane in board.lanes %}
			{% include 'dashboard/update_lane.html.twig' with {
				lane: lane,
				form: laneEditForms[lane.id],
				checked: (openEditLaneId is defined and lane.id == openEditLaneId)
			} only %}
		{% endfor %}
	</div>

{% endblock %}
