{% extends 'base.html.twig' %}

{% block title %}{{ board.title }} - Dashboard{% endblock %}

{% block body %}
<div class="container mx-auto px-6 py-8">
    {# Header du dashboard #}
    <div class="flex items-center justify-between mb-8">
        <div>
            <a href="{{ path('app_board_index') }}" class="text-blue-400 hover:text-blue-300 text-sm mb-2 inline-block">
                ← Back to Boards
            </a>
            <h1 class="text-3xl font-bold text-white">{{ board.title }}</h1>
            <p class="text-gray-400">Board Dashboard</p>
        </div>
        <div class="text-right">
            <p class="text-sm text-gray-400">Created</p>
            <p class="text-white">
                {% if board.createdAt %}
                    {{ board.createdAt|date('M d, Y') }}
                {% else %}
                    -
                {% endif %}
            </p>
        </div>
    </div>

    {# Contenu du dashboard - à adapter selon vos besoins #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {# Carte statistiques #}
        <div class="bg-gray-800 p-6 rounded-lg">
            <h3 class="text-lg font-semibold text-white mb-2">Tasks</h3>
            <p class="text-3xl font-bold text-blue-400">0</p>
            <p class="text-gray-400 text-sm">Total tasks</p>
        </div>
        
        <div class="bg-gray-800 p-6 rounded-lg">
            <h3 class="text-lg font-semibold text-white mb-2">Completed</h3>
            <p class="text-3xl font-bold text-green-400">0</p>
            <p class="text-gray-400 text-sm">Tasks done</p>
        </div>
        
        <div class="bg-gray-800 p-6 rounded-lg">
            <h3 class="text-lg font-semibold text-white mb-2">Progress</h3>
            <p class="text-3xl font-bold text-yellow-400">0%</p>
            <p class="text-gray-400 text-sm">Completion rate</p>
        </div>
    </div>

    {# Section pour les tâches ou autres éléments du board #}
    <div class="mt-8">
        <div class="bg-gray-800 rounded-lg p-6">
            <h2 class="text-xl font-semibold text-white mb-4">Board Content</h2>
            <div class="text-center text-gray-400 py-12">
                <p>This is where your board content will appear.</p>
                <p class="text-sm mt-2">Add tasks, lists, or other board elements here.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}