{# templates/dashboard/update_card.html.twig #}
<input type="checkbox" id="card_edit_modal_{{ card.id }}" class="modal-toggle" {{ checked ? 'checked' }}/>
<div class="modal" role="dialog">
	<div class="modal-box">
		<h3 class="text-lg font-bold mb-4">Edit Card</h3>

		{{ form_start(form, {
      action: path('card_edit', { id: card.id }),
      attr: { novalidate: 'novalidate' }
    }) }}
		{{ form_widget(form) }}
		<div class="modal-action">
			<button class="btn btn-primary" type="submit">Update</button>
			<label for="card_edit_modal_{{ card.id }}" class="btn" type="button">Cancel</label>
		</div>
		{{ form_end(form) }}

		{# Delete form #}
		<form method="post" action="{{ path('app_card_delete', {id: card.id}) }}" onsubmit="return confirm('Are you sure you want to delete this card?');">
			<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ card.id) }}">
			<button class="btn btn-error btn-sm" type="submit">Delete Card</button>
		</form>
	</div>
	<label class="modal-backdrop" for="card_edit_modal_{{ card.id }}">Close</label>
</div>