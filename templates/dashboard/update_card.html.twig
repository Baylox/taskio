
{# templates/dashboard/update_card.html.twig #}
<input type="checkbox" id="card_edit_modal_{{ card.id }}" class="modal-toggle" {{ checked ? 'checked' }}/>
<div class="modal backdrop-blur-sm">
	<div class="modal-box bg-slate-800 border border-slate-700/50 shadow-2xl max-w-lg w-full mx-4">
		
		{# Header with close button #}
		<div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-700/50">
			<div class="flex items-center gap-3">
				<div class="p-2 bg-blue-500/20 rounded-lg">
					<svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
					</svg>
				</div>
				<h3 class="text-xl font-bold text-white">Edit Card</h3>
			</div>
			<label for="card_edit_modal_{{ card.id }}" class="btn btn-sm btn-ghost text-slate-400 hover:text-white hover:bg-slate-700/50 rounded-full p-2">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
				</svg>
			</label>
		</div>

		<div class="space-y-4 mb-6">
			{{ form_start(form, {
				action: path('card_edit', { id: card.id }),
				attr: { novalidate: 'novalidate' }
			}) }}
			<div class="styled-form-fields">
				{{ form_widget(form) }}
			</div>
			<div class="modal-action flex items-center justify-between pt-6 border-t border-slate-700/50">
				<div class="flex gap-3">
					<button class="btn bg-gradient-to-r from-blue-500 to-cyan-500 hover:from-blue-400 hover:to-cyan-400 text-white border-none shadow-md hover:shadow-lg transition-all duration-200 px-6" type="submit">
						<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
						</svg>
						Update
					</button>
					<label for="card_edit_modal_{{ card.id }}" class="btn btn-ghost text-slate-300 hover:text-white hover:bg-slate-700/50 border border-slate-600 px-6" type="button">Cancel</label>
				</div>
			</div>
			{{ form_end(form) }}
		</div>



		{# Delete form #}
		<form method="post" action="{{ path('app_card_delete', {id: card.id}) }}" 
			  onsubmit="return confirm('Are you sure you want to delete this card?');" 
			  class="absolute bottom-4 right-4">
			<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ card.id) }}">
			<button class="btn btn-ghost btn-sm w-8 h-8 p-0 min-h-0 text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors duration-200" 
					type="submit" 
					title="Delete card">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
				</svg>
			</button>
		</form>

	</div>
	<label class="modal-backdrop" for="card_edit_modal_{{ card.id }}">Close</label>
</div>
