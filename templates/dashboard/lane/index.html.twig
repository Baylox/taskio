{% extends 'base.html.twig' %}

{% block title %}Lane index{% endblock %}

{% block body %}
    <h1>Lane index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Position</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for lane in lanes %}
            <tr>
                <td>{{ lane.id }}</td>
                <td>{{ lane.title }}</td>
                <td>{{ lane.position }}</td>
                <td>
                    <a href="{{ path('app_lane_show', {'id': lane.id}) }}">show</a>
                    <a href="{{ path('app_lane_edit', {'id': lane.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_lane_new') }}">Create new</a>
{% endblock %}
