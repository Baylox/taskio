{% extends 'base.html.twig' %}

{% block title %}{{ adminMode|default(false) ? 'Admin - All Boards' : 'My Boards' }}{% endblock %}

{% block body %}
	<div class="container mx-auto px-6 py-8">
		{# Title and Stats #}
		<div class="flex justify-between items-start mb-8">
			<div class="flex items-center gap-3">
				<h1 class="text-2xl font-semibold text-gray-200">
					{{ adminMode|default(false) ? 'Admin - Board Management' : 'My Boards' }}
				</h1>
				{% if adminMode|default(false) %}
					<span class="bg-red-600 text-white px-3 py-1 rounded text-xs font-medium uppercase">ADMIN MODE</span>
				{% endif %}
			</div>
			<div class="text-right">
				<div class="text-sm text-gray-400">{{ adminMode|default(false) ? 'All Boards' : 'My Boards' }}</div>
				<div class="text-2xl font-bold text-white">{{ boards|length }}</div>
			</div>
		</div>

		{# Create Board Button #}
		<div class="mb-6 flex justify-end">
			<a href="{{ path('app_board_new') }}" class="bg-cyan-500 hover:bg-cyan-600 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors inline-flex items-center gap-2" aria-label="Create a new board">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
				</svg>
				Create Board
			</a>
		</div>

		{# Board Table #}
		<div class="overflow-hidden">
			<table class="w-full">
				<thead>
					<tr class="border-b border-gray-700">
						<th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Title</th>
						{% if adminMode|default(false) %}
							<th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Owner</th>
						{% endif %}
						<th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for board in boards %}
						<tr class="border-b border-gray-800 hover:bg-gray-800/50 transition-colors">
							<td class="px-6 py-4">
								<a href="{{ path('app_board_edit', {'id': board.id}) }}" class="text-white font-medium hover:text-cyan-400 transition-colors">
									{{ board.title }}
								</a>
							</td>
							{% if adminMode|default(false) %}
								<td class="px-6 py-4">
									<div class="text-sm text-gray-400">
										{{ board.owner ? board.owner.email : 'Unknown' }}
									</div>
								</td>
							{% endif %}
							<td class="px-6 py-4">
								<div class="flex items-center justify-end gap-3">
									{# Dashboard button with icon #}
									<a href="{{ path('app_board_dashboard', {'id': board.id}) }}" class="text-gray-400 hover:text-white transition-colors" title="View dashboard for {{ board.title }}">
										<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 0v10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2H9z"/>
										</svg>
									</a>
									{# Delete button #}
									{{ include('board/_delete_form.html.twig') }}
								</div>
							</td>
						</tr>
					{% else %}
						{# Empty state #}
						<tr>
							<td colspan="{{ adminMode|default(false) ? '3' : '2' }}" class="px-6 py-12 text-center">
								<div class="flex flex-col items-center space-y-3">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
									</svg>
									<p class="text-lg font-medium text-gray-500">
										{{ adminMode|default(false) ? 'No boards in the system' : 'No boards found' }}
									</p>
									<p class="text-sm text-gray-400 mb-2">
										{{ adminMode|default(false) ? 'No boards have been created yet' : 'Get started by creating your first board' }}
									</p>
									<a href="{{ path('app_board_new') }}" class="bg-cyan-500 hover:bg-cyan-600 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors inline-flex items-center gap-2" aria-label="Create your first board">
										<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
										</svg>
										Create Board
									</a>
								</div>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}