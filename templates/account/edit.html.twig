{% extends 'base.html.twig' %}

{% block title %}My Profile
{% endblock %}

{% block body %}
	<div class="min-h-screen flex items-center justify-center bg-base-200">
		<div class="w-full max-w-md bg-base-100 shadow-xl rounded-xl p-8">

			<div class="text-center mb-8">
				<h1 class="text-2xl font-bold text-base-content">My Profile</h1>
				<p class="text-base-content/70 mt-2">Update your profile information</p>
			</div>

			{% for message in app.flashes('success') %}
				<div class="alert alert-success mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
					</svg>
					<span>{{ message }}</span>
				</div>
			{% endfor %}

			{% for message in app.flashes('error') %}
				<div class="alert alert-error mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
					</svg>
					<span>{{ message }}</span>
				</div>
			{% endfor %}

			{{ form_start(form) }}

			{{ form_row(form.name, {
				'attr': {
					'class': 'input input-bordered w-full text-base-content bg-base-100',
					'placeholder': 'First Name'
				},
				'label_attr': {'class': 'label-text text-base-content font-medium'}
			}) }}

			{{ form_row(form.lastname, {
				'attr': {
					'class': 'input input-bordered w-full text-base-content bg-base-100',
					'placeholder': 'Last Name'
				},
				'label_attr': {'class': 'label-text text-base-content font-medium'}
			}) }}

			<div class="divider my-6 text-base-content/60">Change Password (optional)</div>

			{{ form_row(form.plainPassword.first, {
				'attr': {
					'class': 'input input-bordered w-full text-base-content bg-base-100',
					'placeholder': 'New Password'
				},
				'label_attr': {'class': 'label-text text-base-content font-medium'},
				'label': 'New Password'
			}) }}

			{{ form_row(form.plainPassword.second, {
				'attr': {
					'class': 'input input-bordered w-full text-base-content bg-base-100',
					'placeholder': 'Confirm New Password'
				},
				'label_attr': {'class': 'label-text text-base-content font-medium'},
				'label': 'Confirm New Password'
			}) }}

			{{ form_rest(form) }}

			<div class="mt-6 space-y-3">
				<button type="submit" class="btn btn-primary w-full">
					Save Changes
				</button>
			</div>

			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
