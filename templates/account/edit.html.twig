{% extends 'base.html.twig' %}

{% block title %}My Profile
{% endblock %}

{% block body %}
	<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-slate-800 to-black overflow-hidden">
		<div class="w-full max-w-md bg-base-100 shadow-xl rounded-xl p-8 border border-white/10 shadow-blue-500/10">

			<div class="text-center mb-8">
				<h1 class="text-2xl font-bold text-base-content">My Profile</h1>
				<p class="text-base-content/70 mt-2">Update your profile information</p>
			</div>

			{% for message in app.flashes('success') %}
				<div class="alert alert-success mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
					</svg>
					<span>{{ message }}</span>
				</div>
			{% endfor %}

			{% for message in app.flashes('error') %}
				<div class="alert alert-error mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
					</svg>
					<span>{{ message }}</span>
				</div>
			{% endfor %}

			{{ form_start(form, {attr: {class: 'space-y-4'}}) }}

			<div class="form-control">
				{{ form_label(form.name, 'First Name', {
					label_attr: {class: 'label'}
				}) }}
				{{ form_widget(form.name, {
					attr: {
						class: 'input input-bordered w-full bg-base-100 focus:input-primary transition-colors',
						placeholder: 'First Name'
					}
				}) }}
				{{ form_errors(form.name) }}
			</div>

			<div class="form-control">
				{{ form_label(form.lastname, 'Last Name', {
					label_attr: {class: 'label'}
				}) }}
				{{ form_widget(form.lastname, {
					attr: {
						class: 'input input-bordered w-full bg-base-100 focus:input-primary transition-colors',
						placeholder: 'Last Name'
					}
				}) }}
				{{ form_errors(form.lastname) }}
			</div>

			<div class="divider my-6 text-base-content/60">Change Password (optional)</div>

			<div class="form-control">
				{{ form_label(form.plainPassword.first, 'New Password', {
					label_attr: {class: 'label'}
				}) }}
				{{ form_widget(form.plainPassword.first, {
					attr: {
						class: 'input input-bordered w-full bg-base-100 focus:input-primary transition-all' ~ (form.plainPassword.first.vars.errors|length > 0 ? ' border-red-500 focus:border-red-500 focus:ring-2 focus:ring-red-200' : ''),
						placeholder: 'Enter new password'
					}
				}) }}
				<label class="label">
					<span class="label-text-alt text-base-content/70">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
						At least 8 characters with uppercase, lowercase, number and special character (@$!%*?&)
					</span>
				</label>
				{{ form_errors(form.plainPassword.first) }}
			</div>

			<div class="form-control">
				{{ form_label(form.plainPassword.second, 'Confirm New Password', {
					label_attr: {class: 'label'}
				}) }}
				{{ form_widget(form.plainPassword.second, {
					attr: {
						class: 'input input-bordered w-full bg-base-100 focus:input-primary transition-all' ~ (form.plainPassword.second.vars.errors|length > 0 ? ' border-red-500 focus:border-red-500 focus:ring-2 focus:ring-red-200' : ''),
						placeholder: 'Confirm new password'
					}
				}) }}
				{{ form_errors(form.plainPassword.second) }}
			</div>

            {# Global errors for the plainPassword field (e.g. mismatch) #}
			{{ form_errors(form.plainPassword) }}

			{{ form_rest(form) }}

			<div class="mt-6 space-y-3">
				<button type="submit" class="btn btn-primary w-full">
					Save Changes
				</button>
			</div>

			{{ form_end(form) }}
		</div>
	</div>
{% endblock %}
