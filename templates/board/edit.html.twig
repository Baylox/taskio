{% extends 'base.html.twig' %}

{% block title %}Edit
	{{ board.title }}
{% endblock %}

{% block body %}
	<div
		class="container mx-auto px-6 py-8">
		{# Flash messages #}
		{% for type, messages in app.flashes %}
			{% for message in messages %}
				<div class="alert alert-{{ type == 'error' ? 'error' : (type == 'warning' ? 'warning' : 'success') }} mb-4">
					<span>{{ message }}</span>
				</div>
			{% endfor %}
		{% endfor %}

		{# Header with title and actions #}
		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-semibold text-gray-200">Edit Board</h1>
			<div
				class="flex items-center gap-2">
				{# Back to list #}
				<a href="{{ path('app_board_index') }}" class="btn btn-ghost btn-sm" title="Back to list" aria-label="Back to boards list">
					<i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
					<span class="sr-only">Back</span>
				</a>
				{# Dashboard #}
				<a href="{{ path('app_board_dashboard', {'id': board.id}) }}" class="btn btn-ghost btn-sm hover:btn-primary focus-visible:ring-2 focus-visible:ring-primary" title="View dashboard for {{ board.title }}" aria-label="View dashboard for {{ board.title }}">
					<i class="fa-solid fa-table-columns" aria-hidden="true"></i>
					<span class="sr-only">Dashboard</span>
				</a>
				{# Delete #}
				{{ include('board/_delete_form.html.twig') }}
			</div>
		</div>

		{# Form card #}
		<div class="bg-gray-800 rounded-lg p-6 mb-8">
			{{ include('board/_form.html.twig', {'button_label': 'Update'}) }}
		</div>

		{# Collaborators section - only visible to owner #}
		{% if is_granted('BOARD_MANAGE_COLLABORATORS', board) %}
			<div class="bg-gray-800 rounded-lg p-6">
				<h2 class="text-xl font-semibold text-gray-200 mb-4">Collaborators</h2>

				{# Invite collaborator form #}
				{{ form_start(collaborator_form, {
					'action': path('app_board_invite_collaborator', {'id': board.id}),
					'attr': {'class': 'mb-6'}
				}) }}
				<div class="flex gap-2">
					{{ form_widget(collaborator_form.email) }}
					<button type="submit" class="btn btn-primary">
						<i class="fa-solid fa-envelope"></i>
						Send Invitation
					</button>
				</div>
				{{ form_errors(collaborator_form.email) }}
				{{ form_end(collaborator_form) }}

				{# Pending invitations #}
				{% if pending_invitations is not empty %}
					<div class="mb-6">
						<h3 class="text-lg font-medium text-gray-300 mb-3">Pending Invitations</h3>
						<div class="space-y-2">
							{% for invitation in pending_invitations %}
								<div class="flex items-center justify-between bg-gray-700 rounded-lg p-3">
									<div class="flex items-center gap-3">
										<i class="fa-solid fa-clock text-blue-400"></i>
										<div>
											<div class="text-sm font-medium text-white">{{ invitation.email }}</div>
											<div class="text-xs text-gray-400">
												Invited {{ invitation.createdAt|date('M d, Y') }} • Expires {{ invitation.expiresAt|date('M d, Y') }}
											</div>
										</div>
									</div>
									<form method="post" action="{{ path('app_board_cancel_invitation', {'id': board.id, 'invitationId': invitation.id}) }}" class="inline">
										<input type="hidden" name="_token" value="{{ csrf_token('cancel_invitation' ~ invitation.id) }}">
										<button type="submit" class="btn btn-ghost btn-sm text-error hover:bg-error hover:text-white" onclick="return confirm('Cancel this invitation?')">
											<i class="fa-solid fa-times"></i>
											Cancel
										</button>
									</form>
								</div>
							{% endfor %}
						</div>
					</div>
				{% endif %}

				{# Collaborators list #}
				<div class="space-y-2">
					<h3 class="text-lg font-medium text-gray-300 mb-3">Active Members</h3>

					{# Owner (non-removable) #}
					<div class="flex items-center justify-between bg-gray-700 rounded-lg p-3">
						<div class="flex items-center gap-3">
							<i class="fa-solid fa-crown text-yellow-500"></i>
							<div>
								<div class="text-sm font-medium text-white">{{ board.owner.email }}</div>
							</div>
						</div>
						<span class="badge badge-warning">Owner</span>
					</div>

					{# Collaborators #}
					{% for collaborator in board.accounts %}
						<div class="flex items-center justify-between bg-gray-700 rounded-lg p-3">
							<div class="flex items-center gap-3">
								<i class="fa-solid fa-user text-gray-400"></i>
								<div>
									<div class="text-sm font-medium text-white">{{ collaborator.email }}</div>
								</div>
							</div>
							<form method="post" action="{{ path('app_board_remove_collaborator', {'id': board.id, 'userId': collaborator.id}) }}" class="inline">
								<input type="hidden" name="_token" value="{{ csrf_token('remove_collaborator' ~ collaborator.id) }}">
								<button type="submit" class="btn btn-ghost btn-sm text-error hover:bg-error hover:text-white" onclick="return confirm('Remove this collaborator from the board?')">
									<i class="fa-solid fa-user-minus"></i>
									Remove
								</button>
							</form>
						</div>
					{% else %}
						<div class="text-center py-8 text-gray-400">
							<i class="fa-solid fa-users text-4xl mb-2 opacity-50"></i>
							<p>No collaborators yet. Send an invitation to start collaborating!</p>
						</div>
					{% endfor %}
				</div>
			</div>
		{% endif %}
	</div>
{% endblock %}
