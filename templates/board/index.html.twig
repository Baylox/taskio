{% extends 'base.html.twig' %}

{% block title %}Board Management{% endblock %}

{% block body %}
<div class="container mx-auto px-6 py-8">
    {# Title #}
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-2xl font-semibold text-gray-200">Board Management</h1>
        
    </div>

    {# Nb Board + Create board #}
    <div class="mb-6">
        <div class="flex items-center gap-4">
            <div class="text-right">
            <p class="text-sm text-gray-400">Total Boards</p>
            <p class="text-2xl font-bold text-white text-left">{{ boards|length }}</p>
        </div>
            <div class="ml-auto">
                <a href="{{ path('app_board_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors">
                    + Create Board
                </a>
            </div>
        </div>
    </div>

    {# Board Table #}
    <div class="bg-gray-800 rounded-lg overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-900">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Title</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
                {% for board in boards %}
                <tr class="hover:bg-gray-750 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                            <div class="flex-shrink-0 h-8 w-8 bg-blue-600 rounded-md flex items-center justify-center mr-3">
                                <span class="text-xs font-bold text-white">{{ board.title|slice(0, 2)|upper }}</span>
                            </div>
                            <div class="text-sm font-medium text-white">{{ board.title }}</div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <div class="flex items-center justify-end gap-2">
                            {# View/Edit #}
                            <button class="text-gray-400 hover:text-white transition-colors" title="View Board">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                </svg>
                            </button>
                            
                            {# Edit #}
                            <button class="text-gray-400 hover:text-white transition-colors" title="Edit Board">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                </svg>
                            </button>

                            {# Delete #}
                            <div class="relative">
                                {{ include('board/_delete_form.html.twig') }}
                            </div>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center">
                        <div class="text-gray-400">
                            <svg class="mx-auto h-12 w-12 text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                            </svg>
                            <p class="text-lg font-medium text-gray-500 mb-2">No boards found</p>
                            <p class="text-sm text-gray-400 mb-4">Get started by creating your first board</p>
                            <a href="{{ path('app_board_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors">
                                + Create Board
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
