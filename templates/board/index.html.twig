{% extends 'base.html.twig' %}

{% block title %}
	{{ adminMode|default(false) ? 'Admin - All Boards' : 'My Boards' }}
{% endblock %}

{% block body %}
	<div
		class="container mx-auto px-6 py-8">
		{# Title #}
		<div class="flex justify-between items-center mb-8">
			<h1 class="text-2xl font-semibold text-gray-200">
				{{ adminMode|default(false) ? 'Admin - Board Management' : 'My Boards' }}
			</h1>
			{% if adminMode|default(false) %}
				<div class="text-sm text-gray-400">
					<span class="bg-red-600 text-white px-2 py-1 rounded text-xs font-medium">ADMIN MODE</span>
				</div>
			{% endif %}
		</div>

		{# Nb Board + Create board #}
		<div class="mb-6">
			<div class="flex items-center gap-4">
				<div class="text-right">
					<p class="text-sm text-gray-400">{{ adminMode|default(false) ? 'All Boards' : 'My Boards' }}</p>
					<p class="text-2xl font-bold text-white text-left">{{ boards|length }}</p>
				</div>
				<div class="ml-auto">
					<a href="{{ path('app_board_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors" aria-label="Create a new board">
						+ Create Board
					</a>
				</div>
			</div>
		</div>

		{# Board Table #}
		<div class="bg-gray-800 rounded-lg overflow-hidden">
			<table class="w-full">
				<thead class="bg-gray-900">
					<tr>
						<th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Title</th>
						{% if adminMode|default(false) %}
							<th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Owner</th>
						{% endif %}
						<th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-700">
					{% for board in boards %}
						<tr class="hover:bg-gray-750 transition-colors">
							<td class="px-6 py-4 whitespace-nowrap">
								<div
									class="flex items-center">
									{# Board Title with link to dashboard #}
									<a href="{{ path('app_board_edit', {'id': board.id}) }}" class="text-sm font-medium text-white">{{ board.title }}</a>
								</div>
							</td>
							{% if adminMode|default(false) %}
								<td class="px-6 py-4 whitespace-nowrap">
									<div class="text-sm text-gray-300">
										{{ board.owner ? board.owner.email : 'Unknown' }}
									</div>
								</td>
							{% endif %}
							<td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
								<div
									class="flex items-center justify-end gap-1">
									{# Dashboard #}
									<a href="{{ path('app_board_dashboard', {'id': board.id}) }}" class="btn btn-ghost btn-sm hover:btn-primary" title="View dashboard for {{ board.title }}" aria-label="View dashboard for {{ board.title }}">
										<i class="fa-solid fa-table-columns"></i>
									</a>
									{# Delete #}
									{{ include('board/_delete_form.html.twig') }}
								</div>
							</td>

						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="px-6 py-12 text-center">
								<div class="text-gray-400">
									<svg class="mx-auto h-12 w-12 text-gray-600 mb-4" fill="none" stroke="currentColor" viewbox="0 0 24 24" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
									</svg>
									<p class="text-lg font-medium text-gray-500 mb-2">{{ adminMode|default(false) ? 'No boards in the system' : 'No boards found' }}</p>
									<p class="text-sm text-gray-400 mb-4">{{ adminMode|default(false) ? 'No boards have been created yet' : 'Get started by creating your first board' }}</p>
									<a href="{{ path('app_board_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors" aria-label="Create your first board">
										+ Create Board
									</a>
								</div>
							</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}
