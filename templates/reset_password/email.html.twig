<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset your password - Taskio</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            color: #a6adbb;
            background-color: #1f2937;
            margin: 0;
            padding: 40px 20px;
        }

        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background: #1f2937;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        .card {
            background: #374151;
            border-radius: 16px;
            overflow: hidden;
        }

        .icon-wrapper {
            width: 80px;
            height: 80px;
            background: #570df8;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 40px auto 20px;
        }

        .icon {
            width: 48px;
            height: 48px;
            color: white;
        }

        .header {
            padding: 0 40px;
            text-align: center;
        }

        .header h1 {
            margin: 0 0 10px 0;
            font-size: 28px;
            font-weight: 700;
            color: white;
        }

        .header p {
            margin: 0 0 30px 0;
            color: rgba(166, 173, 187, 0.7);
            font-size: 16px;
        }

        .content {
            padding: 0 40px 40px;
            text-align: center;
        }

        .alert {
            background: rgba(87, 13, 248, 0.1);
            border: 1px solid rgba(87, 13, 248, 0.3);
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 24px;
            text-align: left;
        }

        .alert p {
            margin: 0;
            font-size: 14px;
            line-height: 1.5;
        }

        .btn {
            display: inline-block;
            background: #570df8;
            color: white;
            padding: 14px 32px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 16px;
            margin: 20px 0;
            transition: background 0.2s;
        }

        .btn:hover {
            background: #4506cb;
        }

        .footer {
            padding: 24px 40px;
            text-align: center;
            color: #9ca3af;
            font-size: 14px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            background: #1f2937;
        }

        .footer p {
            margin: 0;
        }

        .footer a {
            color: #570df8;
            text-decoration: none;
        }

        .expiry-text {
            font-size: 14px;
            color: #9ca3af;
            margin-top: 16px;
        }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="card">
            <div class="icon-wrapper">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
            </div>

            <div class="header">
                <h1>Reset Your Password</h1>
                <p>We received a request to reset your password</p>
            </div>

            <div class="content">
                <div class="alert">
                    <p>Click the button below to choose a new password. This link will expire in {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.</p>
                </div>

                <a href="{{ url('app_reset_password', {token: resetToken.token}) }}" class="btn">Reset Password</a>

                <p class="expiry-text">If you didn't request a password reset, you can safely ignore this email.</p>
            </div>
        </div>

        <div class="footer">
            <p>Sent from <strong>Taskio</strong> — Your productivity companion</p>
        </div>
    </div>
</body>
</html>
