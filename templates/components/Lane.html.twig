{# templates/components/Lane.html.twig #}
<div id="lane-{{ lane.id }}" class="lane w-80 shrink-0 bg-slate-800/60 backdrop-blur-sm rounded-xl border border-slate-700/50 shadow-xl hover:shadow-2xl transition-all duration-300 hover:border-slate-600/70">
	{# Lane Header #}
	<header class="flex items-center justify-between p-4 border-b border-slate-700/50 bg-slate-800/40 rounded-t-xl">
		<div class="flex items-center gap-3">
			<div class="w-3 h-3 rounded-full bg-gradient-to-r from-cyan-400 to-blue-500"></div>
			<h2 class="font-semibold text-white text-lg">{{ lane.title }}</h2>
			<span class="bg-slate-700/50 text-slate-300 text-xs px-2 py-1 rounded-full">
				{{ lane.cards|length }}
			</span>
		</div>
		
		<div class="flex gap-2">
			{# Edit Lane Button #}
			<label for="lane_edit_modal_{{ lane.id }}" 
				   class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-slate-300 hover:text-white bg-slate-700/50 hover:bg-slate-600/50 rounded-lg transition-all duration-200 cursor-pointer border border-slate-600/50 hover:border-slate-500">
				<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
				</svg>
				Edit
			</label>
			
			{# Add Card Button #}
			<button class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-white bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-400 hover:to-blue-400 rounded-lg transition-all duration-200 shadow-lg hover:shadow-cyan-500/25" 
					data-action="click->modal#open" 
					data-modal-target-id="modal-card-create-{{ lane.id }}">
				<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
				</svg>
				Add Card
			</button>
		</div>
	</header>

	{# Cards Container #}
	<div class="cards p-4 space-y-3 min-h-[200px] max-h-[600px] overflow-y-auto">
		{% for card in lane.cards %}
			<div class="card-wrapper">
				{% include 'components/Card.html.twig' with { card: card } %}
			</div>
		{% endfor %}

		{# Empty State for Lane #}
		{% if lane.cards|length == 0 %}
			<div class="empty-state flex flex-col items-center justify-center py-8 text-slate-400">
				<svg class="w-12 h-12 mb-3 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
				</svg>
				<p class="text-sm text-center">No cards yet</p>
				<button class="mt-2 text-xs text-cyan-400 hover:text-cyan-300 transition-colors" 
						data-action="click->modal#open" 
						data-modal-target-id="modal-card-create-{{ lane.id }}">
					Create your first card
				</button>
			</div>
		{% endif %}
	</div>

	{# Lane Footer with Stats #}
	{% if lane.cards|length > 0 %}
		<footer class="px-4 py-3 border-t border-slate-700/50 bg-slate-800/40 rounded-b-xl">
			<div class="flex items-center justify-between text-xs text-slate-400">
				<span>{{ lane.cards|length }} card{{ lane.cards|length > 1 ? 's' : '' }}</span>
				{% set completedCards = lane.cards|filter(card => card.completed ?? false) %}
				{% if completedCards|length > 0 %}
					<span class="text-green-400">{{ completedCards|length }} completed</span>
				{% endif %}
			</div>
		</footer>
	{% endif %}
</div>

{# Card Creation Modal #}
<div id="modal-card-create-{{ lane.id }}" 
	 class="modal fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 {{ (openCardModalId is defined and openCardModalId == lane.id) ? '' : 'hidden' }}" 
	 data-controller="modal">
	
	<div class="modal-box bg-slate-800 border border-slate-700/50 rounded-xl shadow-2xl max-w-md w-full mx-4 transform transition-all duration-300">
		{# Modal Header #}
		<header class="flex items-center justify-between p-6 border-b border-slate-700/50">
			<div class="flex items-center gap-3">
				<div class="w-8 h-8 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-lg flex items-center justify-center">
					<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
					</svg>
				</div>
				<div>
					<h3 class="font-bold text-lg text-white">Add New Card</h3>
					<p class="text-sm text-slate-400">to {{ lane.title }}</p>
				</div>
			</div>
			<button class="text-slate-400 hover:text-white transition-colors" data-action="click->modal#close">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
				</svg>
			</button>
		</header>

		{# Modal Body #}
		<div class="p-6">
			{{ form_start(cardForms[lane.id], {
				action: path('card_new', { laneId: lane.id }),
				attr: { 
					novalidate: 'novalidate',
					class: 'space-y-4'
				}
			}) }}

			<div class="form-fields space-y-4">
				{{ form_widget(cardForms[lane.id]) }}
			</div>

			{# Modal Actions #}
			<div class="flex items-center gap-3 mt-6 pt-4 border-t border-slate-700/50">
				<button type="submit" 
						class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-400 hover:to-blue-400 text-white font-medium rounded-lg transition-all duration-200 shadow-lg hover:shadow-cyan-500/25">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
					</svg>
					Save Card
				</button>
				<button type="button" 
						class="px-4 py-2.5 text-slate-300 hover:text-white bg-slate-700/50 hover:bg-slate-600/50 font-medium rounded-lg transition-all duration-200 border border-slate-600/50 hover:border-slate-500" 
						data-action="click->modal#close">
					Cancel
				</button>
			</div>

			{{ form_end(cardForms[lane.id]) }}
		</div>
	</div>
</div>

{# Custom Styles for Lane Component #}
<style>
	/* Cards container scrollbar */
	.cards::-webkit-scrollbar {
		width: 4px;
	}
	
	.cards::-webkit-scrollbar-track {
		background: rgba(148, 163, 184, 0.1);
		border-radius: 2px;
	}
	
	.cards::-webkit-scrollbar-thumb {
		background: linear-gradient(180deg, #06b6d4, #3b82f6);
		border-radius: 2px;
	}

	/* Card animations */
	.card-wrapper {
		animation: slideInCard 0.3s ease-out;
	}
	
	@keyframes slideInCard {
		from {
			opacity: 0;
			transform: translateX(-10px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	/* Modal animations */
	.modal:not(.hidden) .modal-box {
		animation: modalSlideIn 0.3s ease-out;
	}
	
	@keyframes modalSlideIn {
		from {
			opacity: 0;
			transform: scale(0.9) translateY(-20px);
		}
		to {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}

	/* Form styling improvements */
	.form-fields input,
	.form-fields textarea,
	.form-fields select {
		@apply bg-slate-700/50 border-slate-600/50 text-white placeholder-slate-400 rounded-lg focus:border-cyan-500 focus:ring-cyan-500/20;
	}

	.form-fields label {
		@apply text-slate-300 font-medium text-sm;
	}

	/* Hover effects for lane */
	.lane:hover {
		transform: translateY(-2px);
	}

	/* Empty state animation */
	.empty-state {
		animation: fadeIn 0.5s ease-out;
	}
	
	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}
</style>