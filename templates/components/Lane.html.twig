<div class="lane bg-gray-800 rounded-md shadow p-3 w-64 flex-shrink-0">
    <h2 class="font-semibold text-white mb-2">{{ lane.title }}</h2>
    <div class="lane-cards space-y-2">
        {% for card in lane.cards %}
            {% include 'dashboard/_card.html.twig' with { card: card } %}
        {% else %}
            <p class="text-gray-400 text-sm">No cards yet</p>
        {% endfor %}
    </div>
</div>
