{# templates/components/Hero.html.twig #}
<section
    {{ attributes.defaults({
        class: 'relative grid ' ~ this.heightClass() ~ ' place-items-center text-center text-base-content overflow-hidden',
        role:  'banner',
        'aria-labelledby': 'hero-title',
    }) }}
>
    <!-- Gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-blue-700 via-slate-800 to-black"></div>

    <!-- Decoration -->
    <div class="absolute top-10 left-10 w-40 h-40 rounded-full bg-indigo-500 opacity-20"></div>
    <div class="absolute top-20 right-20 w-56 h-56 rounded-full bg-purple-500 opacity-20"></div>
    <div class="absolute bottom-10 left-32 w-48 h-48 rounded-full bg-blue-500 opacity-20"></div>
    <div class="absolute bottom-24 right-40 w-32 h-32 rounded-full bg-pink-500 opacity-20"></div>
    <div class="absolute top-1/4 left-0 w-28 h-28 rounded-full bg-indigo-400 opacity-20"></div>
    <div class="absolute bottom-1/3 right-0 w-36 h-36 rounded-full bg-purple-400 opacity-20"></div>
    <div class="absolute top-1/3 right-1/4 w-20 h-20 rounded-full bg-blue-400 opacity-20"></div>
    <div class="absolute bottom-1/4 left-1/4 w-24 h-24 rounded-full bg-pink-400 opacity-20"></div>

    <!-- Content -->
    <div class="relative z-20 px-6 py-16 md:py-24 max-w-5xl">
        <h1 id="hero-title" class="text-4xl md:text-6xl font-extrabold leading-tight text-white mb-8">
            {{ title }}
        </h1>

        {% if subtitle %}
            <p class="text-lg md:text-xl text-base-content/80 mb-10 max-w-xl mx-auto">
                {{ subtitle }}
            </p>
        {% endif %}

        {% if ctaHref and ctaLabel %}
            <a href="{{ ctaHref }}" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-600 hover:from-cyan-400 hover:via-blue-400 hover:to-purple-500 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl hover:shadow-cyan-500/30 cursor-pointer transform hover:scale-105 hover:-translate-y-0.5" >
                {{ ctaLabel }}
            </a>
        {% endif %}
    </div>
</section>
